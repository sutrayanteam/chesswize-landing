:80 {
	root * /srv
	encode zstd gzip

	# SPA fallback — any path that isn't a real file gets index.html
	try_files {path} /index.html

	# Long-cache the hashed Vite build assets
	@static path /assets/*
	header @static {
		Cache-Control "public, max-age=31536000, immutable"
	}

	# Videos / posters / images — serve with Range support (Caddy does this
	# natively) and a short cache window so we can rotate assets.
	@media path *.mp4 *.webp *.svg *.png *.jpg *.jpeg
	header @media {
		Cache-Control "public, max-age=86400"
		Accept-Ranges "bytes"
	}

	# Sensible defaults for the SPA entry
	@html path /index.html /
	header @html {
		Cache-Control "no-cache"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Frame-Options "DENY"
	}

	file_server
}
