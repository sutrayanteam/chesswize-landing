# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ─────────────────────────────────────────────────────────────────────
# Analytics (frontend) — set via Coolify build env or .env.local
# Each is independent: leave blank to disable that provider, the rest
# keep working. All are baked into the bundle at build time (Vite).
# ─────────────────────────────────────────────────────────────────────

# PostHog — primary clickstream + autocapture. Free tier is 1M events/mo.
# Get the key from https://app.posthog.com → Project Settings → API Keys
VITE_POSTHOG_KEY=""
# Defaults to https://app.posthog.com if unset. Set to your reverse-
# proxy / EU instance if applicable.
VITE_POSTHOG_HOST="https://app.posthog.com"

# Google Analytics 4 — secondary conversion reporting. Use the
# Measurement ID, NOT the Stream ID.
# https://analytics.google.com → Admin → Data Streams → Web → "G-XXXXXXXXXX"
VITE_GA4_ID=""

# Google Ads — conversion tracking for the chesswize.in account
# (CHESSWIZE AD ACCOUNT, customer 175-872-8547). The conversion ID is
# the AW-prefixed account-level Google tag ID (NOT the customer ID —
# Google issues a separate AW- ID per Ads tag). The label is per
# conversion action (the "CWZ - Book Free Demo - Primary" action).
# Both must be set for the /thank-you page to fire 'event conversion'.
# Without the label, gtag still loads (so the conversion linker stamps
# gclid into form submits + sets _gcl_* cookies) but no conversion
# event is sent.
#
# For ChessWize the known values are:
#   VITE_GADS_CONVERSION_ID="AW-17213475222"
#   VITE_GADS_CONVERSION_LABEL="E6eKCLmd3accEJaTg5BA"
#
# Re-discoverable via the Google Ads API:
#   POST /v22/customers/1758728547/googleAds:search
#   query: SELECT conversion_action.tag_snippets FROM conversion_action
#          WHERE conversion_action.id = 7599509177
#   The tagSnippets[].eventSnippet contains the full
#   `'send_to': 'AW-XXX/<label>'` literal — split on `/` to get both.
#
# Enhanced Conversions: enable in Ads UI on the conversion action
# (one-time, not env-driven). Once on, the /thank-you page sends
# sha256(email) + sha256(phone) alongside every conversion.
VITE_GADS_CONVERSION_ID=""
VITE_GADS_CONVERSION_LABEL=""

# Sentry — error tracking only (NOT clickstream). Free tier covers a
# small project. Get the DSN from Sentry → Project Settings → Client Keys.
VITE_SENTRY_DSN=""
